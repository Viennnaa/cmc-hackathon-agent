# CoinMarketCap Data API — https://coinmarketcap.com/api/
CMC_API_KEY=

# Trust Wallet Agent Kit — https://portal.trustwallet.com (needed from Day 3)
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
# Wallet password for executed swaps on headless Linux (macOS uses keychain)
TWAK_WALLET_PASSWORD=

# BNB Agent SDK (ERC-8004 identity, bsc-testnet)
WALLET_PASSWORD=
RPC_URL=https://bsc-testnet-rpc.publicnode.com   # SDK default RPC is dead

# Runtime
AGENT_MODE=paper            # paper | live
POLL_INTERVAL_SECONDS=60
STARTING_CAPITAL_USDT=150
